// ----------------------------------------------------------------------------
// Test profile
// ----------------------------------------------------------------------------

params {
    // Small test inputs
    input    = "${projectDir}/assets/sampledata_test.tsv"
    metadata = "${projectDir}/assets/metadata_test.tsv"

    // Test output
    outdir = "results_test"

    // Keep test run small
    downsample = 1000
    learn_nbases = 1e5

    // Relax filtering for tiny data
    min_asv_total_freq = 1
    min_asv_sample = 0

    // Optional: tiny test databases
    silva_dir = "${projectDir}/databases/silva"
    gtdb_dir  = "${projectDir}/databases/gtdb"
    gg2_dir   = "${projectDir}/databases/gg2"
}

// ----------------------------------------------------------------------------
// Test resource limits
// ----------------------------------------------------------------------------

process {
    resourceLimits = [
        cpus: 4,
        memory: 8.GB,
        time: 2.h
    ]
}
