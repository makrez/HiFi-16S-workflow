params {
    // Pipeline metadata
    version = false
    help = false

    // Required inputs
    input = false
    metadata = false

    // QC / preprocessing
    filterQ = 20
    downsample = 0
    skip_primer_trim = false
    max_ee = 2
    min_len = 1000
    max_len = 1600

    // Primer sequences
    front_p = 'AGRGTTYGATYMTGGCTCAG'
    adapter_p = 'AAGTCGTAACAAGGTARCY'

    // error model learning
    learn_nbases = 10e6

    // Denoising parameters
    band_size = 16
    homopolymer_gap_penalty = 1
    omegac = 1e-40

    // Chimera Removal parameters
    chimera_method = 'consensus'
    min_parent_fold = 1.0

    // Taxonomy Databases
    download_db = false
    download_targets = null

    silva_dir = "${projectDir}/databases/silva"
    gtdb_dir  = "${projectDir}/databases/gtdb"
    gg2_dir   = "${projectDir}/databases/gg2"

    db_to_prioritize = 'GG2'

    // Output
    outdir = "results"
    publish_dir_mode = "symlink"

    // Resources
    cutadapt_cpu = 16

    // Runtime
    enable_conda = false
    enable_container = false
}

// ----------------------------------------------------------------------------
// Container configuration
// ----------------------------------------------------------------------------
docker {
    enabled = params.enable_container
}

singularity {
    enabled = params.enable_container
    autoMounts = true
}

// ----------------------------------------------------------------------------
// Reports
// ----------------------------------------------------------------------------
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/execution_report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/execution_timeline.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/execution_trace.txt"
}

// ----------------------------------------------------------------------------
// Profiles
// ----------------------------------------------------------------------------
profiles {

    standard {
        conda {
            useMamba = false
            enabled = true
            createTimeout = '2 h'
            cacheDir = "$HOME/nf_conda/"
        }
        params.enable_conda = true
        params.enable_container = false

        docker.enabled = false
        singularity.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    conda {
        conda {
            useMamba = false
            enabled = true
            createTimeout = '2 h'
            cacheDir = "$HOME/nf_conda/"
        }
        params.enable_conda = true
        params.enable_container = false

        docker.enabled = false
        singularity.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    docker {
        docker.enabled = true
        singularity.enabled = false
        params.enable_conda = false
        params.enable_container = true

        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "$HOME/nf_conda/singularity"
        params.enable_conda = false
        params.enable_container = true

        docker.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }
}

// ----------------------------------------------------------------------------
// Process resources
// ----------------------------------------------------------------------------
process {
    cpus = 8
    memory = 8.GB
    beforeScript = 'mkdir -p ./tmp/'

    withLabel: cpu_def {
        cpus = 4
        memory = 4.GB
    }

    withLabel: cpu8 {
        cpus = 8
        memory = 8.GB
    }

    withLabel: cpu16 {
        cpus = 8
        memory = 8.GB
    }
}

// ----------------------------------------------------------------------------
// Executor
// ----------------------------------------------------------------------------
executor {
    name = 'local'
}

// ----------------------------------------------------------------------------
// Environment
// ----------------------------------------------------------------------------
env {
    TMPDIR = './tmp/'
}
