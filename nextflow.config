params {
    // if 
    custom_config_version = 'master'
    custom_config_base    = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"

    // Pipeline metadata
    version = null
    help = null

    // Required inputs
    input = null
    metadata = null

    // QC / preprocessing
    filterQ = 20
    downsample = 0
    skip_primer_trim = false
    max_ee = 2
    min_len = 1000
    max_len = 1600

    // Primer sequences
    front_p = 'AGRGTTYGATYMTGGCTCAG'
    adapter_p = 'AAGTCGTAACAAGGTARCY'

    // Error model learning
    learn_nbases = 10e6

    // Denoising parameters
    band_size = 16
    homopolymer_gap_penalty = 1
    omegac = 1e-40

    // Chimera removal parameters
    chimera_method = 'consensus'
    min_parent_fold = 1.0

    // ASV filtering
    min_asv_total_freq = 10
    min_asv_sample = 0

    // Taxonomy databases
    download_db = false
    download_targets = null

    silva_dir = "${projectDir}/databases/silva"
    gtdb_dir  = "${projectDir}/databases/gtdb"
    gg2_dir   = "${projectDir}/databases/gg2"

    db_to_prioritize = 'GG2'

    // Output
    outdir = "results"
    publish_dir_mode = "symlink"

    // Runtime
    enable_conda = false
    enable_container = false
}

includeConfig 'conf/base.config'

profiles {
    standard {
        conda {
            useMamba = false
            enabled = true
            createTimeout = '2 h'
            cacheDir = "$HOME/nf_conda/"
        }

        params.enable_conda = true
        params.enable_container = false

        docker.enabled = false
        singularity.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    conda {
        conda {
            useMamba = false
            enabled = true
            createTimeout = '2 h'
            cacheDir = "$HOME/nf_conda/"
        }

        params.enable_conda = true
        params.enable_container = false

        docker.enabled = false
        singularity.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    docker {
        docker.enabled = true
        singularity.enabled = false

        params.enable_conda = false
        params.enable_container = true

        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true

        params.enable_conda = false
        params.enable_container = true

        docker.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }

    test {
        includeConfig 'conf/test.config'
    }
}

includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) \
    ? "${params.custom_config_base}/nfcore_custom.config" \
    : "/dev/null"

